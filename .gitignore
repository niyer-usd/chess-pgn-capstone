.git-credentials
.gitconfig
.jupyter/
.ipython/
.ipynb_checkpoints/

# System / editor
.DS_Store
__pycache__/
untitled.chat

# SageMaker / Jupyter runtime state (regenerated automatically)
.local/
.npm/
.sagemaker_sql_editor_api_cache/
.virtual_documents/
.aws/
.cache/
